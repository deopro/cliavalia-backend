      "required": false
    },
    "min_reviews": {
      "type": "integer",
      "required": true,
      "min": 0
    },
    "icon": {
      "type": "string",
      "required": false
    },
    "color": {
      "type": "string",
      "required": false
    },
    "sort_order": {
      "type": "integer",
      "required": false,
      "default": 0
    },
    "is_legend": {
      "type": "boolean",
      "required": false,
      "default": false
    },
    "badge_label": {
      "type": "string",
      "required": false
    },
    "badge_label_en": {
      "type": "string",
      "required": false
    }
  }
